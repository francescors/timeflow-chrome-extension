{
  "manifest_version": 3,
  "name": "TimeFlow \u2014 Web Time Tracker",
  "version": "1.0",
  "description": "Track time spent on websites with a clean dashboard.",
  "permissions": [
    "tabs",
    "storage",
    "idle"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}